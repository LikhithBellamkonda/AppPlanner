rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string
    //   - email: string (required)
    //   - photoURL: string
    //   - createdAt: timestamp
    //
    // Collection: tasks
    // Document ID: taskId
    // Fields:
    //   - userId: string (required)
    //   - title: string (required, size < 200)
    //   - category: string (size < 100)
    //   - duration: string (size < 50)
    //   - priority: string (enum: High, Normal, Urgent, Routine)
    //   - completed: bool (required)
    //   - time: string (size < 20)
    //   - progress: number (0-100)
    //   - createdAt: timestamp
    //
    // Collection: insights
    // Document ID: insightId
    // Fields:
    //   - userId: string (required)
    //   - title: string (required, size < 200)
    //   - description: string (required, size < 1000)
    //   - type: string (enum: productivity, alert, recommendation)
    //   - action: string (optional)
    //   - createdAt: timestamp
    //
    // Collection: performance
    // Document ID: performanceId
    // Fields:
    //   - userId: string (required)
    //   - day: string (required, size < 10)
    //   - value: number (required, 0-100)
    //   - type: string (enum: deep, routine)
    //   - createdAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "likhithbellamkonda@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, maxLen) {
      return !(field in request.resource.data) || (request.resource.data[field] is string && request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'displayName', 'email', 'photoURL', 'createdAt', 'role']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() > 0 &&
             (data.role == 'user' || !('role' in data));
    }

    function isValidTask(data) {
      return hasRequiredFields(['userId', 'title', 'completed']) &&
             hasOnlyAllowedFields(['userId', 'title', 'category', 'duration', 'priority', 'completed', 'time', 'progress', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.completed is bool &&
             isValidOptionalString('category', 100) &&
             isValidOptionalString('duration', 50) &&
             isValidOptionalString('time', 20) &&
             (!( 'priority' in data) || data.priority in ['High', 'Normal', 'Urgent', 'Routine']) &&
             (!( 'progress' in data) || (data.progress is number && data.progress >= 0 && data.progress <= 100));
    }

    function isValidInsight(data) {
      return hasRequiredFields(['userId', 'title', 'description', 'type']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() < 200 &&
             data.description is string && data.description.size() < 1000 &&
             data.type in ['productivity', 'alert', 'recommendation'];
    }

    function isValidPerformance(data) {
      return hasRequiredFields(['userId', 'day', 'value', 'type']) &&
             data.userId == request.auth.uid &&
             data.day is string && data.day.size() < 10 &&
             data.value is number && data.value >= 0 && data.value <= 100 &&
             data.type in ['deep', 'routine'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidTask(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidTask(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /insights/{insightId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidInsight(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidInsight(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /performance/{performanceId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidPerformance(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidPerformance(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
